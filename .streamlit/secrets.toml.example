# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored and will NOT be pushed to GitHub.

# MapMyIndia / Mappls OAuth credentials — get from https://apis.mappls.com/console/
MAPMYINDIA_CLIENT_ID     = "your_client_id_here"
MAPMYINDIA_CLIENT_SECRET = "your_client_secret_here"
